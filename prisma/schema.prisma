generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ServiceStatus {
  UNKNOWN
  UP
  DOWN
}

enum HealthCheckStatus {
  SUCCESS
  FAILURE
}

enum IncidentStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

enum IncidentSeverity {
  SEV1
  SEV2
  SEV3
}

enum IncidentEventType {
  CREATED
  ACKNOWLEDGED
  RESOLVED
}

enum NotificationChannel {
  DISCORD
}

enum NotificationStatus {
  SENT
  FAILED
  SKIPPED
}

model Service {
  id                  String        @id @default(cuid())
  name                String
  url                 String
  expectedStatusCode  Int           @default(200)
  intervalSeconds     Int           @default(60)
  timeoutSeconds      Int           @default(5)
  failureThreshold    Int           @default(3)
  currentStatus       ServiceStatus @default(UNKNOWN)
  consecutiveFailures Int           @default(0)
  isActive            Boolean       @default(true)
  lastCheckedAt       DateTime?
  lastSuccessAt       DateTime?
  lastFailureAt       DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  healthChecks        HealthCheck[]
  incidents           Incident[]

  @@map("services")
}

model HealthCheck {
  id             String            @id @default(cuid())
  serviceId      String
  service        Service           @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  status         HealthCheckStatus
  statusCode     Int?
  responseTimeMs Int
  errorMessage   String?
  checkedAt      DateTime          @default(now())

  @@map("health_checks")
}

model Incident {
  id              String            @id @default(cuid())
  serviceId       String
  service         Service           @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  title           String
  severity        IncidentSeverity  @default(SEV2)
  status          IncidentStatus    @default(OPEN)
  startedAt       DateTime
  resolvedAt      DateTime?
  durationSeconds Int?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  events          IncidentEvent[]
  notifications   Notification[]

  @@map("incidents")
}

model IncidentEvent {
  id         String            @id @default(cuid())
  incidentId String
  incident   Incident          @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  type       IncidentEventType
  message    String
  metadata   Json?
  createdAt  DateTime          @default(now())

  @@map("incident_events")
}

model Notification {
  id           String              @id @default(cuid())
  incidentId   String
  incident     Incident            @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  channel      NotificationChannel
  eventType    IncidentEventType
  status       NotificationStatus
  errorMessage String?
  sentAt       DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@unique([incidentId, eventType, channel])
  @@map("notifications")
}
